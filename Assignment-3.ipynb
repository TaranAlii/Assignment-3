   "source": [
    "from sklearn.preprocessing import PolynomialFeatures\n",
    "from sklearn.linear_model import LinearRegression\n",
    "\n",
    "# 1. Transform the input feature using Polynomial Features (Degree = 3)\n",
    "poly_reg = PolynomialFeatures(degree=3)\n",
    "X_poly_train = poly_reg.fit_transform(X_train)\n",
    "X_poly_test = poly_reg.transform(X_test)\n",
    "\n",
    "# 2. Train a Polynomial Regression model\n",
    "lin_reg = LinearRegression()\n",
    "lin_reg.fit(X_poly_train, y_train)\n",
    "\n",
    "print(\"Model Training Complete.\")\n",
    "print(f\"Intercept (beta_0): {lin_reg.intercept_:.2f}\")\n",
    "print(f\"Coefficients (beta_1, beta_2, beta_3): {lin_reg.coef_[1:]}\")"
   ]
