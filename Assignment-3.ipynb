    "# Generate smooth levels for plotting the regression curve (1 to 10 with high density)\n",
    "X_grid = np.linspace(float(X.min()), float(X.max()), 100)\n",
    "X_grid = X_grid.reshape((len(X_grid), 1))\n",
    "X_poly_grid = poly_reg.transform(X_grid)\n",
    "y_grid_pred = lin_reg.predict(X_poly_grid)\n",
